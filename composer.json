{
    "name": "mehediishere/laravel-modular",
    "description": "Native zero-dependency modular architecture for Laravel ERP systems. Provides module discovery, sidebar management, and artisan scaffolding.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "modular",
        "erp",
        "modules",
        "sidebar",
        "architecture"
    ],
    "authors": [
        {
            "name": "Mehedi Hassan",
            "email": "mehediishere@gmail.com",
            "homepage": "https://github.com/mehediishere"
        }
    ],
    "homepage": "https://github.com/mehediishere/laravel-modular",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/filesystem": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0",
        "illuminate/cache": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Mehediishere\\LaravelModular\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mehediishere\\LaravelModular\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mehediishere\\LaravelModular\\ModularServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
